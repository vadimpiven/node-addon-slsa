{
  "name": "node-addon-slsa",
  "version": "0.0.0",
  "description": "Supply-chain provenance verification for npm packages with prebuilt native addons",
  "keywords": [
    "attestation",
    "provenance",
    "sigstore"
  ],
  "homepage": "https://github.com/vadimpiven/node-addon-slsa",
  "bugs": {
    "url": "https://github.com/vadimpiven/node-addon-slsa/issues"
  },
  "license": "Apache-2.0 OR MIT",
  "author": "Vadim Piven <vadim@piven.tech> (https://piven.tech)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vadimpiven/node-addon-slsa.git"
  },
  "bin": {
    "slsa": "./bin/slsa.mjs"
  },
  "files": [
    "dist/**/*",
    "bin/**/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "bump-version": "npm version --no-git-tag-version --allow-same-version",
    "type-check": "pnpm exec tsc --noEmit",
    "build": "vite build && pnpm pack --out package.tar.gz",
    "test:vitest": "pnpm exec vitest run --coverage",
    "pretest": "pnpm run build",
    "test": "pnpm run type-check && pnpm run test:vitest",
    "ci-build": "pnpm run build",
    "ci-test": "pnpm run test"
  },
  "devDependencies": {
    "@sigstore/bundle": "catalog:",
    "@sigstore/core": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "markdownlint-cli2": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "sigstore": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": "^10.26.0"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
