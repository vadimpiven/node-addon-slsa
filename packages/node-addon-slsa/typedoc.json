{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/index.ts"],
  "out": "docs",
  "plugin": ["typedoc-theme-oxide"],
  "theme": "oxide",
  "name": "node-addon-slsa",
