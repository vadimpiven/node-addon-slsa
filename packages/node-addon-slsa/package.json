{
  "name": "node-addon-slsa",
  "version": "0.0.0",
  "description": "Provenance verification for prebuilt native addons with GitHub attestations",
  "keywords": [
    "attestation",
    "binary",
    "native-addon",
    "prebuilt",
    "provenance",
    "security",
    "sigstore",
    "slsa",
    "supply-chain"
  ],
  "homepage": "https://vadimpiven.github.io/node-addon-slsa",
  "bugs": {
    "url": "https://github.com/vadimpiven/node-addon-slsa/issues"
  },
  "license": "Apache-2.0 OR MIT",
  "author": "Vadim Piven <vadim@piven.tech> (https://piven.tech)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vadimpiven/node-addon-slsa.git",
    "directory": "packages/node-addon-slsa"
  },
  "bin": {
    "slsa": "./bin/slsa.mjs"
  },
  "files": [
    "dist/**/*",
    "bin/**/*",
    "LICENSE-*.txt",
    "NOTICE.txt",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "bump-version": "npm version --no-git-tag-version --allow-same-version",
    "type-check": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "prebuild": "pnpm run type-check",
    "build": "vite build && typedoc && node --experimental-strip-types scripts/generate-schemas.ts",
    "postbuild": "pnpm pack --out package.tar.gz",
    "pretest": "pnpm run build",
    "test": "vitest run --coverage",
    "ci-build": "pnpm run build",
    "ci-test": "pnpm run test"
  },
  "devDependencies": {
    "@actions/attest": "catalog:",
    "@actions/core": "catalog:",
    "@node-addon-slsa/internal": "workspace:*",
    "@sigstore/bundle": "catalog:",
    "@sigstore/core": "catalog:",
    "@sigstore/tuf": "catalog:",
    "@sigstore/verify": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "dedent": "catalog:",
    "sigstore": "catalog:",
    "typescript": "catalog:",
    "undici": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
